{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "target": "ES2020",
    "composite": true,
    "types": ["node", "jest"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
  },
    "references": [
    { "path": "../adapter-types" }, // Reference to other local packages
    { "path": "../core" }
   ],
  "include": [
  "src/**/*",    
  // "**/*.test.ts",
  "**/*.spec.ts"
  ],
  "exclude": ["node_modules", "dist", "**/__tests__/**"]
}