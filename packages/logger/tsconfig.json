{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {                                                                                                                                                                    
    "rootDir": "src",
    "outDir": "dist",                                                                                                                                                                     
    "composite": true,
    "declaration": true,  
    "resolveJsonModule": true,  
    "types": ["node", "jest"],
    "emitDeclarationOnly": false,  
    "tsBuildInfoFile": "../../.cache/tsbuildinfo/logger.tsbuildinfo"                                       
  },
  "include": [
    "src",
    "src/**/*",
    "package.json"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "coverage",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/__test__/**",
    "src/**/__tests__/**"
  ]
}