{
  "extends": "../../tsconfig.base.json", // Inherit common settings
  "compilerOptions": {                                                                                   
    "rootDir": "src",
    "outDir": "dist",                                                                                                                                                                     
    "composite": true,
    "declaration": true,  
    "resolveJsonModule": true,  
    "types": ["node", "jest"],
    "emitDeclarationOnly": false,  
    "tsBuildInfoFile": "dist/.tsbuildinfo",                       
  },
  "include": [
    "src",
    "src/**/*",
    // "package.json"
  ],
  "exclude": [
    "node_modules",
    "**/__tests__/**"
  ],
}