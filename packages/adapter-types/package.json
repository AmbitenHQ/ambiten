{
  "name": "@tenra/adapter-types",
  "version": "1.0.0",
  "description": "Tenra multi-tenacy adapter types",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "changeset": "pnpm run changeset",
    "release": "pnpm changeset version",
    "publish": "pnpm --recursive publish --access public --tag latest --no-git-checks"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.20.0",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=10.20.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3"
  }
}