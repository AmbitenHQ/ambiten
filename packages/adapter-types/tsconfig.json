{
  "extends": "../../tsconfig.base.json", // Inherit common settings
  "compilerOptions": {                                                                                   
    "rootDir": "src",
    "outDir": "dist",                                                                                                                                                                    
    "types": ["node", "jest"],
    "composite": true, 
    "noEmit": false,
    "declaration": true,
    "esModuleInterop": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,  
    "sourceMap": true,    
    "tsBuildInfoFile": "../../.cache/tsbuildinfo/adapter-types.tsbuildinfo"       
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.json",
    "assets"
  ]
}