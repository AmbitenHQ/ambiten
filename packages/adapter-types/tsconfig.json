{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",                                                                                                                                                                    
    // "declarationDir": "./dist/types",
    "composite": true,
    "declaration": true,  
    "resolveJsonModule": true,        
    "tsBuildInfoFile": ".tsbuildinfo"
  },
  "include": ["src/**/*", "package.json"],
  "exclude": [
    "node_modules", 
    "dist",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
  ]
} 