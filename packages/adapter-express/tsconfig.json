{
  "extends": "../../tsconfig.base.json", // Inherit common settings
  "compilerOptions": {                                                                                   
    "rootDir": "src",
    "outDir": "dist",                                                                                                                                                                     
    "types": ["node", "jest"],
    "esModuleInterop": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,  
    "resolveJsonModule": true, 
    "sourceMap": true,
    "noEmit": false,              
  },
  "references": [
    { "path": "../adapter-runtime" }, // Reference to other local packages
    {"path": "../adapter-types"}
  ],
  "include": [
    "src/**/*.ts",
    "src/**/*.json",
    "assets"
  ],
    "exclude": [
    "node_modules",
    "dist",
    "coverage",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/__test__/**",
    "src/**/__tests__/**"
  ]
}