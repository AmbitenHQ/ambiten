{
  "extends": "../../tsconfig.base.json", // Inherit common settings
  "compilerOptions": {                                                                                   
    "rootDir": "src",
    "outDir": "dist",                                                                                                                                                                     
    "composite": true,
    "declaration": true,  
    "resolveJsonModule": true,  
    "types": ["node", "jest"],
    "emitDeclarationOnly": false,   
    "tsBuildInfoFile": ".tsbuildinfo",
    // "incremental": false                     
  },
  "include": [
    "src/**/*",
    "src/**/*.json",
    // "package.json",
    "assets"
  ],
  "references": [
    { "path": "../logger" }, // Reference to other local packages
    {"path": "../adapter-types"}
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/__test__/**/*"
  ],
}