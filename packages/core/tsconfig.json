{
  "extends": "../../tsconfig.base.json", // Inherit common settings
  "compilerOptions": {                                                                                   
    "rootDir": "src",
    "outDir": "dist",                                                                                                                                                                     
    "composite": true,
    "declaration": true,  
    "resolveJsonModule": true,  
    "types": ["node", "jest"],
    "emitDeclarationOnly": false,   
    "tsBuildInfoFile": "../../.cache/tsbuildinfo/core.tsbuildinfo"            
  },
    "references": [
    { "path": "../logger" }, // Reference to other local packages
    {"path": "../adapter-types"}
  ],
  "include": [
    "src/**/*.ts",
    "src/**/*.json",
    "assets"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "coverage",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/__test__/**",
    "src/**/__tests__/**"
  ]
}