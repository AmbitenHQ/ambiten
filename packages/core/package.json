{
  "name": "@ambiten/core",
  "version": "1.0.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Core library for Ambiten, providing essential functionalities and utilities for building applications with Ambiten.",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "browser": "./dist/index-browser.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ambiten": "./bin/bootstrap.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./browser": {
      "import": "./dist/index-browser.js",
      "require": "./dist/index-browser.js",
      "types": "./dist/browser.d.ts"
    },
    "./bin": {
      "import": "./dist/index-cli.js",
      "require": "./dist/index-cli.js",
      "types": "./dist/cli.d.ts"
    },
    "./bundle": "./dist/ambiten-logger.js",
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE",
    "package.json",
    "!dist/scripts"
  ],
  "scripts": {
    "build:node": "webpack --config webpack.node.config.js",
    "build:cli": "webpack --config webpack.cli.config.js",
    "build:web": "webpack --config webpack.web.config.js",
    "build:types": "tsc -p tsconfig.json --excludeDirectories **/node_modules",
    "build": "pnpm run build:types && pnpm run build:node && pnpm run build:cli && pnpm run build:web",
    "lint": "eslint src",
    "clean": "rimraf dist",
    "typedoc": "typedoc --options typedoc.json",
    "release": "pnpm changeset version",
    "test": "jest --detectOpenHandles --coverage",
    "prepack": "pnpm clean && pnpm build",
    "publish": "pnpm --recursive publish --access public --tag latest --no-git-checks"
  },
  "release": {
    "branches": [
      "main"
    ]
  },
  "keywords": [
    "mongodb",
    "odm",
    "core",
    "Ambiten",
    "library"
  ],
  "author": "Emmanuel Nodolomwanyi",
  "maintainers": [
    {
      "name": "Emmanuel Nodolomwanyi"
    }
  ],
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AmbitenHQ/ambiten.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/AmbitenHQ/ambiten/issues"
  },
  "homepage": "https://ambiten.dev",
  "dependencies": {
    "@babel/runtime": "7.28.4",
    "@inquirer/prompts": "^8.3.2",
    "@ambiten/logger": "workspace:*",
    "buffer": "6.0.3",
    "commander": "14.0.2",
    "fs-extra": "11.3.3",
    "node-cron": "4.2.0",
    "prompts": "^2.4.2"
  },
  "peerDependencies": {
    "@graphql-tools/schema": "10.0.23",
    "ajv": ">=8.18.0",
    "ajv-formats": "3.0.1",
    "express": "^5.1.0",
    "express-serve-static-core": "^0.1.1",
    "graphql": "16.11.0",
    "graphql-http": "1.22.4",
    "graphql-redis-subscriptions": "2.7.0",
    "graphql-subscriptions": "3.0.0",
    "graphql-tag": "2.12.6",
    "graphql-ws": "5.16.2",
    "jsonwebtoken": "9.0.2",
    "mongodb": "^5 || ^6",
    "redis": "4.7.1",
    "ws": ">=8.20.1"
  },
  "peerDependenciesMeta": {
    "mongodb": {
      "optional": false
    },
    "graphql": {
      "optional": false
    }
  },
  "overrides": {
    "graphql": "16.11.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/eslint-parser": "^7.28.5",
    "@babel/plugin-transform-modules-commonjs": "^7.27.1",
    "@babel/plugin-transform-runtime": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/js": "^9.39.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@ambiten/adapter-types": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/express": "^5.0.6",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.3",
    "@types/webpack": "5.28.5",
    "axios": "^1.13.2",
    "babel-loader": "^10.0.0",
    "clean-webpack-plugin": "^4.0.0",
    "console-browserify": "^1.2.0",
    "conventional-changelog": "^7.2.0",
    "crypto-browserify": "^3.12.1",
    "dotenv": "16.4.7",
    "eslint": "^9.39.2",
    "eslint-webpack-plugin": "^5.0.2",
    "figlet": "^1.9.4",
    "globals": "^14.0.0",
    "graphql": "16.11.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.4.3",
    "path-browserify": "^1.0.1",
    "semantic-release": "^24.2.9",
    "socket.io-client": "^4.8.3",
    "stream-browserify": "^3.0.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.6",
    "ts-loader": "9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "tslib": "2.8.1",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.30.1",
    "webpack": "5.104.1",
    "webpack-cli": "6.0.1",
    "webpack-node-externals": "3.0.0",
    "webpack-remove-debug": "0.1.0",
    "webpack-shebang-plugin": "1.1.8"
  },
  "packageManager": "pnpm@10.20.0",
  "engines": {
    "node": ">=20.11.0"
  }
}