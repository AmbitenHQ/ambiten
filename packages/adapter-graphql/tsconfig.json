{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "types": ["node", "jest"],
    "target": "ES2020",
    "composite": true,
    "skipLibCheck": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo"
  },
  "references": [
    {"path": "../adapter-runtime"},
    { "path": "../adapter-types" }, // Reference to other local packages
   ],
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/__test__/*"],
}