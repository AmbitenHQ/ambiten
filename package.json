{
  "name": "ambiten",
  "version": "1.0.0",
  "description": "",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm run build:ordered",
    "build:ordered": "node scripts/build-all.js --build --clean --verify",
    "test": "pnpm --recursive test",
    "lint": "pnpm -w exec eslint \"packages/**/src/**/*.{ts,tsx,js,jsx}\"",
    "lint:fix": "pnpm -w exec eslint \"packages/**/src/**/*.{ts,tsx,js,jsx}\" --fix",
    "clean": "rimraf packages/*/dist .cache",
    "build:logger": "pnpm --filter @ambiten/logger build",
    "build:core": "pnpm --filter @ambiten/core build",
    "build:create": "pnpm --filter @ambiten/create build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "changelog:generate": "changeset version",
    "docs:sanitize": "node ./scripts/sanitize-typedoc-md.js",
    "api:docs": "pnpm docs:api && pnpm run docs:sanitize",
    "docs:api": "typedoc --out api-docs packages/core/src packages/logger/src",
    "typecheck": "pnpm -w -r exec tsc --build",
    "publish": "pnpm -r publish --access public --tag latest --no-git-checks"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AmbitenHQ/ambiten.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "bugs": {
    "url": "https://github.com/AmbitenHQ/ambiten/issues"
  },
  "homepage": "https://github.com/AmbitenHQ/ambiten#readme",
  "packageManager": "pnpm@10.20.0",
  "engines": {
    "node": ">=20.11.0"
  },
  "devDependencies": {
    "@changesets/changelog-git": "^0.2.1",
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@eslint/js": "^9.39.2",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.10.4",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "figlet": "^1.9.4",
    "gh-pages": "^6.3.0",
    "jest": "^29.7.0",
    "rimraf": "^6.1.2",
    "ts-jest": "^29.4.11",
    "tslib": "^2.8.1",
    "typedoc": "^0.28.18",
    "typedoc-plugin-markdown": "^4.11.0",
    "typedoc-vitepress-theme": "^1.1.2",
    "typescript": "^5.9.3",
    "typescript-cached-transpile": "^0.0.6",
    "typescript-eslint": "8.30.1",
    "vitepress": "^1.6.4"
  },
  "dependencies": {
    "fs-extra": "^11.3.3",
    "minimist": "^1.2.8",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0"
  }
}