{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2020", 
      "ES2022.Error",
      "ES2022.Object",
      "esnext.disposable",
      "DOM.Iterable", 
      "DOM"
      ],  
    "moduleDetection": "force",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "types": ["node", "jest"],
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "isolatedModules": true, 
    "allowJs": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "forceConsistentCasingInFileNames": true,
    "allowSyntheticDefaultImports": true,
    "noEmitOnError": true,
    "resolvePackageJsonExports": true,
    "resolveJsonModule": true, 
    "inlineSourceMap": false,                                                                                                                                    
    "noImplicitAny": false,                            
    "strict": true,                                                                  
    "skipLibCheck": true, 
    "jsx": "react-jsx"                              
  },
  "include": [
    "packages/**/src/**/*", 
    "docs/*", 
    ],
  "exclude": [
   "node_modules", 
   "**/node_modules/*", 
   "dist",
   "packages/core/examples", 
   "packages/*/src/__test__/**"]
}
